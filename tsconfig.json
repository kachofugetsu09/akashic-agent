{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "baseUrl": ".",
    "paths": {
      "akashic-dashboard": ["types/akashic-dashboard.d.ts"]
    },
    "noEmit": true
  },
  "include": ["plugins/**/*.ts", "types/**/*.d.ts"]
}
