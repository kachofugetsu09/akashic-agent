{
  "provider": "qwen",
  "model": "qwen3.5-plus",
  "light_model": "qwen-flash",
  "light_api_key": "${QWEN_API_KEY}",
  "light_base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
  "api_key": "${QWEN_API_KEY}",
  "base_url": "https://coding.dashscope.aliyuncs.com/v1",
  "system_prompt": "You are Akashic, a helpful AI assistant with access to tools. Always respond in the same language the user uses.",
  "max_tokens": 8192,
  "max_iterations": 40,
  "extra_body": {
    "enable_thinking": false
  },
  "channels": {
    "telegram": {
      "token": "${TELEGRAM_BOT_TOKEN}",
      "allowFrom": ["your_username"]
    },
    "qq": {
      "bot_uin": "123456789",
      "allowFrom": ["987654321"],
      "groups": [
        {
          "groupId": "111111111",
          "allowFrom": ["987654321"],
          "requireAt": true
        }
      ]
    }
  },
  "proactive": {
    "enabled": true,
    "default_channel": "telegram",
    "default_chat_id": "your_chat_id",
    "preset": "daily",
    "features": {
      "memory_retrieval_enabled": true,
      "preference_retrieval_enabled": true,
      "research_enabled": true,
      "fitbit_enabled": false,
      "skill_actions_enabled": false
    },
    "feed_poller_enabled": true,
    "feed_poller_interval_seconds": 150,
    "feed_poller_fetch_limit": 20,
    "feed_poller_buffer_ttl_hours": 48,
    "feed_poller_buffer_max_per_source": 100,
    "feed_poller_read_limit": 50,
    "interest_filter": {
      "enabled": true,
      "memory_max_chars": 4000,
      "keyword_max_count": 100,
      "min_token_len": 2,
      "min_score": 0.12,
      "top_k": 10,
      "exploration_ratio": 0.2
    },
    "fitbit_url": "http://127.0.0.1:18765",
    "fitbit_poll_seconds": 300,
    "fitbit_monitor_path": "",
    "skill_actions_path": "",
    "overrides": {},
    "agent_tick": {
      "enabled": false,
      "model": "",
      "max_steps": 20,
      "content_limit": 5,
      "web_fetch_max_chars": 8000,
      "context_prob": 0.03,
      "delivery_cooldown_hours": 1
    }
  },
  "tool_search_enabled": true,
  "memory_optimizer_enabled": true,
  "memory_optimizer_interval_seconds": 3600,
  "memory_v2": {
    "enabled": true,
    "embed_model": "text-embedding-v3",
    "top_k_history": 8,
    "score_threshold": 0.45,
    "score_thresholds": {
      "procedure": 0.66,
      "preference": 0.5,
      "event": 0.5,
      "profile": 0.5
    },
    "relative_delta": 0.2,
    "inject_limits": {
      "max_chars": 6000,
      "line_max": 600,
      "event_profile": 4
    },
    "route_intention_enabled": true,
    "gate_llm_timeout_ms": 1600,
    "gate_max_tokens": 200,
    "hyde_enabled": true,
    "hyde_timeout_ms": 2000
  },
  "memory_window": 40
}
